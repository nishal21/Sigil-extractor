			<div class="os-section">
				<div class="os-header">
					<i class="fa-brands fa-linux"></i>
					<h2>LINUX (AMD64 / X86_64)</h2>
				</div>
				<div class="dl-grid">
					<div class="dl-card">
						<div class="dl-text">
							<h3>Debian Package</h3>
							<span>SIGIL_0.1.0_amd64.deb</span>
							<code class="hash" title="Click to copy SHA256" onclick="navigator.clipboard.writeText('615517956a76e21069d412d706e813a196cece7a77f2608aa0f744a07f64554e')">SHA256: 615517...f64554e</code>
						</div>
						<a href="https://github.com/nishal21/Sigil-extractor/releases/download/v0.1.0/SIGIL_0.1.0_amd64.deb" class="btn btn-secondary"><i class="fa-solid fa-download"></i> .DEB</a>
					</div>
					<div class="dl-card">
						<div class="dl-text">
							<h3>RPM Package</h3>
							<span>SIGIL-0.1.0-1.x86_64.rpm</span>
							<code class="hash" title="Click to copy SHA256" onclick="navigator.clipboard.writeText('5377a2f432339c85e5a90d0334fbcc7d34ba65742381dba70bc32c6c2e98517a')">SHA256: 5377a2...e98517a</code>
						</div>
