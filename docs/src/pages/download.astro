						</div>
						<a href="https://github.com/nishal21/Sigil-extractor/releases/download/v0.1.0/SIGIL_0.1.0_x64_en-US.msi" class="btn btn-secondary"><i class="fa-solid fa-download"></i> .MSI</a>
					</div>
				</div>
			</div>

			<div class="os-section">
				<div class="os-header">
					<i class="fa-brands fa-apple"></i>
					<h2>MACOS (AARCH64)</h2>
				</div>
				<div class="dl-grid">
					<div class="dl-card">
						<div class="dl-text">
							<h3>Disk Image</h3>
							<span>SIGIL_0.1.0_aarch64.dmg</span>
							<code class="hash" title="Click to copy SHA256" onclick="navigator.clipboard.writeText('465ac68865f50c07681f75efbe0527f2c7a0bbc79d8a0c7db88bae110078cd81')">SHA256: 465ac6...078cd81</code>
						</div>
						<a href="https://github.com/nishal21/Sigil-extractor/releases/download/v0.1.0/SIGIL_0.1.0_aarch64.dmg" class="btn btn-secondary"><i class="fa-solid fa-download"></i> .DMG</a>
					</div>
					<div class="dl-card">
						<div class="dl-text">
							<h3>Compressed App</h3>
							<span>SIGIL_aarch64.app.tar.gz</span>
							<code class="hash" title="Click to copy SHA256" onclick="navigator.clipboard.writeText('16c922f3529ac89e36abdc5de59ace762b7be40af2740954d16cffee016b52cc')">SHA256: 16c922...16b52cc</code>
						</div>
						<a href="https://github.com/nishal21/Sigil-extractor/releases/download/v0.1.0/SIGIL_aarch64.app.tar.gz" class="btn btn-secondary"><i class="fa-solid fa-download"></i> .TAR.GZ</a>
