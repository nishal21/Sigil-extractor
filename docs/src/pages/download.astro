					<div class="dl-card">
						<div class="dl-text">
							<h3>AppImage</h3>
							<span>SIGIL_0.1.0_amd64.AppImage</span>
							<code class="hash" title="Click to copy SHA256" onclick="navigator.clipboard.writeText('daf1fad726e078dc1db966abfac6a7f63a0631127825c2625ce682f787853b7f')">SHA256: daf1fa...7853b7f</code>
						</div>
						<a href="https://github.com/nishal21/Sigil-extractor/releases/download/v0.1.0/SIGIL_0.1.0_amd64.AppImage" class="btn btn-secondary"><i class="fa-solid fa-download"></i> APPIMAGE</a>
					</div>
				</div>
			</div>
			
			<div class="meta">
				<a href="https://github.com/nishal21/Sigil-extractor/releases/tag/v0.1.0" target="_blank" rel="noopener noreferrer" class="accent-link">
					<i class="fa-solid fa-code-commit"></i> View Release v0.1.0 on GitHub
				</a>
			</div>
		</div>
	</section>
</Layout>

<style>
.download-page {
	padding: var(--space-xl) var(--space-m);
}

.download-content {
	max-width: 1200px;
	width: 100%;
}

h1 {
	font-size: var(--step-hero);
	margin-bottom: var(--space-m);
	line-height: 0.9;
}

.subtitle {
	font-size: var(--step-1);
	color: var(--text-muted);
	margin-bottom: var(--space-xl);
	max-width: 60ch;
}

.os-section {
	margin-bottom: var(--space-xl);
}

.os-header {
	display: flex;
	align-items: center;
	gap: var(--space-s);
	border-bottom: 1px solid var(--border);
	padding-bottom: var(--space-s);
	margin-bottom: var(--space-l);
}

.os-header i {
	font-size: var(--step-2);
	color: var(--accent);
}

.os-header h2 {
	font-size: var(--step-2);
	margin: 0;
}

.dl-grid {
	display: grid;
	grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
	gap: var(--space-m);
}

.dl-card {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: var(--space-m);
	padding: var(--space-m);
	border: 1px solid var(--border);
	background: var(--bg-surface);
	transition: all 0.2s ease;
}

.dl-text {
	display: flex;
	flex-direction: column;
	gap: 0.25rem;
}

.dl-text h3 {
	font-size: var(--step-0);
	margin: 0;
	color: var(--text-main);
	text-transform: none;
}

.dl-text span {
	font-family: 'Space Grotesk', system-ui, sans-serif;
	font-size: var(--step--1);
	color: var(--text-muted);
	letter-spacing: 0.02em;
}

.hash {
	font-family: monospace;
	font-size: 0.75rem;
	background: var(--bg-main);
	color: var(--text-muted);
	padding: 0.2rem 0.4rem;
	border: 1px solid var(--border);
	margin-top: 0.5rem;
	display: inline-block;
	width: fit-content;
	cursor: pointer;
	transition: color 0.2s, border-color 0.2s;
}

.hash:hover {
	color: var(--accent);
	border-color: var(--accent);
}

.hash:active {
	background: var(--accent);
	color: #000;
}

.dl-card .btn {
	min-height: 40px;
	height: 40px;
	padding: 0 var(--space-s);
	font-size: var(--step--1);
	flex-shrink: 0;
}

.dl-card:hover {
	border-color: var(--accent);
}

.meta {
	padding-top: var(--space-xl);
	border-top: 1px solid var(--border);
	font-family: 'Space Grotesk', system-ui, sans-serif;
	text-transform: uppercase;
	font-size: var(--step--1);
	letter-spacing: 0.05em;
}

.accent-link {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	color: var(--text-muted);
	text-decoration: underline;
	text-decoration-color: transparent;
	transition: all 0.2s ease;
}

.accent-link:hover {
	color: var(--accent);
	text-decoration-color: var(--accent);
}

@media (max-width: 768px) {
	.dl-grid {
		grid-template-columns: 1fr;
	}
	
	.dl-card {
		flex-direction: column;
		align-items: stretch;
	}
	
	.dl-card .btn {
		width: 100%;
		margin-top: var(--space-s);
	}
}
</style>
