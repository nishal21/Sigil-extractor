					<i class="fa-brands fa-windows"></i>
					<h2>WINDOWS</h2>
				</div>
				<div class="dl-grid">
					<div class="dl-card">
						<div class="dl-text">
							<h3>Executable Installer</h3>
							<span>SIGIL_0.1.0_x64-setup.exe</span>
							<code class="hash" title="Click to copy SHA256" onclick="navigator.clipboard.writeText('0c4465fe595e1632b86ed49813119b5366c70e055fa9cb1baee18fa26a29c349')">SHA256: 0c4465...29c349</code>
						</div>
						<a href="https://github.com/nishal21/Sigil-extractor/releases/download/v0.1.0/SIGIL_0.1.0_x64-setup.exe" class="btn btn-secondary"><i class="fa-solid fa-download"></i> .EXE</a>
					</div>
					<div class="dl-card">
						<div class="dl-text">
							<h3>MSI Installer</h3>
							<span>SIGIL_0.1.0_x64_en-US.msi</span>
