---
import Layout from '../layouts/Layout.astro';

// Base path helper
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---

<Layout title="Preserve Your Legacy">
	<!-- Massive, subtle watermark background -->
	<div class="bg-watermark">
		<img src={`${base}/favicon.svg`} alt="Sigil Watermark" />
	</div>

	<section class="container hero">
		<div class="hero-top">
			<span class="badge">ZERO-TRUST DESKTOP ENGINE</span>
		</div>
		
		<div class="hero-split">
			<div class="hero-content">
				<h1 class="hero-title">DENY AI SCRAPERS.<br><span class="accent">PROTECT YOUR ART.</span></h1>
				
				<p class="hero-desc">Embed invisible, cryptographically secure signatures directly into your pixels. No cloud. No tracking. Complete ownership of your digital legacy.</p>
				
				<div class="hero-actions">
					<a href={`${base}/download`} class="btn btn-primary"><i class="fa-solid fa-download"></i> DOWNLOAD SETUP</a>
					<a href="https://github.com/nishal21/Sigil-extractor" target="_blank" rel="noopener noreferrer" class="btn btn-secondary"><i class="fa-brands fa-github"></i> VIEW SOURCE</a>
				</div>
			</div>

			<!-- Real UI Preview based on user image -->
			<div class="hero-ui-preview">
				<div class="terminal-window">
					<div class="terminal-header">
						<span>SIGIL // ZERO-KNOWLEDGE STEGANOGRAPHY v1.0.0</span>
						<span class="status"><span class="dot"></span> KEYCHAIN: SECURED</span>
					</div>
					<div class="terminal-body">
						<!-- Mockup of the user's provided UI -->
						<div class="panel">
							<div class="panel-title">[01] IDENTITY MATRIX</div>
							<div class="panel-content success-box">
								<p class="success-text">IDENTITY IS SECURED IN NATIVE KEYCHAIN.</p>
								<div class="danger-btn">PURGE IDENTITY</div>
							</div>
						</div>
						
						<div class="panel">
							<div class="panel-title">[02] THE FORGE</div>
							<div class="panel-content">
								<div class="forge-options">
									<span class="accent">EXPORT</span>
									<span>FORMAT</span>
									<span>ALGORITHM</span>
								</div>
								<div class="forge-dropdown">
									LOSSLESS SECURE (.PNG) [RECOMMENDED]
								</div>
								<div class="drop-zone">
									<div class="drop-btn">[ SELECT ASSETS TO PROTECT ]</div>
									<p>DRAG & DROP IMAGES HERE</p>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
.bg-watermark {
	position: fixed;
	top: 50%;
	left: 50%;
	transform: translate(-50%, -50%);
	width: 90vw;
	height: 90vw;
	max-width: 900px;
	max-height: 900px;
	opacity: 0.03; /* Extremely subtle texture */
	z-index: -1;
	pointer-events: none;
}

.bg-watermark img {
	width: 100%;
	height: 100%;
	object-fit: contain;
}

.hero {
	display: flex;
	flex-direction: column;
	justify-content: center;
	min-height: calc(100vh - 100px);
	position: relative;
	padding: var(--space-xl) var(--space-m);
}

.hero-top {
	margin-bottom: var(--space-l);
}

.badge {
	font-family: 'Space Grotesk', system-ui, sans-serif;
	font-size: var(--step--1);
	letter-spacing: 0.1em;
	color: var(--accent);
	border: 1px solid var(--accent);
	padding: 0.5rem 1rem;
	display: inline-block;
}

.hero-split {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: var(--space-xl);
	align-items: center;
}

.hero-title {
	font-size: var(--step-hero);
	margin-bottom: var(--space-m);
	word-wrap: break-word;
	line-height: 0.9;
}

.hero-desc {
	font-size: var(--step-0);
	color: var(--text-muted);
	margin-bottom: var(--space-xl);
	line-height: 1.6;
	max-width: 50ch;
}

.hero-actions {
	display: flex;
	gap: var(--space-m);
	flex-wrap: wrap;
}

/* UI Mockup Styling */
.hero-ui-preview {
	width: 100%;
	perspective: 1000px;
}

.terminal-window {
	background: var(--bg-main);
	border: 1px solid var(--border);
	font-family: 'Courier New', Courier, monospace;
	box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
	transform: rotateY(-5deg) rotateX(5deg);
	transition: transform 0.5s ease;
}

.terminal-window:hover {
	transform: rotateY(0deg) rotateX(0deg);
}

.terminal-header {
	display: flex;
	justify-content: space-between;
	padding: 1rem;
	border-bottom: 1px solid var(--border);
	font-size: 0.75rem;
	color: var(--accent);
	letter-spacing: 0.05em;
}

.status {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	color: var(--text-muted);
}

.dot {
	width: 8px;
	height: 8px;
	background: var(--accent);
	box-shadow: 0 0 5px var(--accent);
}

.terminal-body {
	padding: 1.5rem;
	display: flex;
	flex-direction: column;
	gap: 1.5rem;
}

.panel {
	border: 1px solid var(--border);
}

.panel-title {
	padding: 0.75rem 1rem;
	border-bottom: 1px solid var(--border);
	font-size: 0.85rem;
	color: var(--text-main);
	letter-spacing: 0.1em;
}

.panel-content {
	padding: 1.5rem;
}

.success-box {
	background: rgba(133, 249, 13, 0.03);
	border-left: 4px solid var(--accent);
	display: flex;
	flex-direction: column;
	gap: 1rem;
}

.success-text {
	color: var(--accent);
	font-size: 0.85rem;
	letter-spacing: 0.05em;
}

.danger-btn {
	color: #ff3333;
	border: 1px solid #ff3333;
	padding: 0.5rem 1rem;
	width: fit-content;
	font-size: 0.75rem;
	letter-spacing: 0.1em;
	cursor: default;
}

.forge-options {
	display: flex;
	gap: 1rem;
	font-size: 0.75rem;
	margin-bottom: 1rem;
	color: var(--text-muted);
	font-weight: bold;
}

.forge-dropdown {
	border: 1px solid var(--border);
	padding: 0.75rem 1rem;
	font-size: 0.8rem;
	color: var(--text-main);
	margin-bottom: 1.5rem;
}

.drop-zone {
	border: 1px dashed var(--border);
	padding: 2rem;
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 1rem;
	text-align: center;
}

.drop-btn {
	background: var(--text-main);
	color: #000;
	padding: 0.75rem 1.5rem;
	font-weight: bold;
	font-size: 0.8rem;
}

.drop-zone p {
	color: var(--text-muted);
	font-size: 0.75rem;
	letter-spacing: 0.1em;
}

@media (max-width: 1024px) {
	.hero-split {
		grid-template-columns: 1fr;
	}
	
	.hero {
		padding-top: var(--space-xl);
	}
	
	.hero-ui-preview {
		margin-top: var(--space-l);
	}
	
	.terminal-window {
		transform: none;
	}
}

@media (max-width: 768px) {
	.hero-actions {
		flex-direction: column;
	}
	
	.hero-actions .btn {
		width: 100%;
	}
}
</style>